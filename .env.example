# Shared URL used by Next.js apps to reach Strapi
NEXT_PUBLIC_API_URL=http://localhost:1337
NEXT_PUBLIC_GA4_MEASUREMENT_ID=

# Deploy webhook listener
DEPLOY_WEBHOOK_TOKEN=replace-with-a-long-random-secret

# Strapi server
HOST=0.0.0.0
PORT=1337

# Strapi required secrets (replace values in real .env)
APP_KEYS=toBeModified1,toBeModified2,toBeModified3,toBeModified4
API_TOKEN_SALT=toBeModified
ADMIN_JWT_SECRET=toBeModified
TRANSFER_TOKEN_SALT=toBeModified
JWT_SECRET=toBeModified

# Default local DB
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# Optional image search providers for AI content
PEXELS_API_KEY=
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# Google Analytics 4 admin dashboard
GA4_PROPERTY_ID=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GA4_REFRESH_TOKEN=
GA4_CACHE_TTL_SECONDS=300
