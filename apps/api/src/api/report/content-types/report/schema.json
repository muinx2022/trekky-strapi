{
  "kind": "collectionType",
  "collectionName": "reports",
  "info": {
    "singularName": "report",
    "pluralName": "reports",
    "displayName": "Report"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "targetType": {
      "type": "enumeration",
      "enum": ["post", "comment", "user"],
      "required": true
    },
    "targetDocumentId": {
      "type": "string",
      "required": true
    },
    "reason": {
      "type": "text"
    },
    "status": {
      "type": "enumeration",
      "enum": ["pending", "reviewed", "dismissed"],
      "default": "pending"
    },
    "reporter": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    }
  }
}
